<Window x:Class="teste.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:teste"
        mc:Ignorable="d"
        Title="Calculadora" Height="414" Width="393" Background="#FF7A9EE4"
        >
        



    <Grid Margin="10,108,10,10" RenderTransformOrigin="0.503,0.503" Background="Black">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>

            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button 
         Grid.Column="0" 
         Grid.Row="0" 
         x:Name="btn0" 
         Content="0" 
         FontSize="20" 
         Background="#FF8A8A8A"
         Margin="5"
         Click="Event_Click"/>

        <Button 
         Grid.Column="1" 
         Grid.Row="0" 
         x:Name="btn1" 
         Content="1" 
         FontSize="20" 
         Background="#FF8A8A8A"
         Margin="5"
        Click="Event_Click"/>
        <Button 
         Grid.Column="2" 
         Grid.Row="0" 
         x:Name="btn2" 
         Content="2" 
         FontSize="20" 
         Background="#FF8A8A8A"
         Margin="5"
        Click="Event_Click"/>
        <Button 
         Grid.Column="0" 
         Grid.Row="1" 
         x:Name="btn3" 
         Content="3" 
         FontSize="20" 
         Background="#FF8A8A8A"
         Margin="5"
        Click="Event_Click"/>
        <Button 
         Grid.Column="1" 
         Grid.Row="1" 
         x:Name="btn4" 
         Content="4" 
         FontSize="20" 
         Background="#FF8A8A8A"
         Margin="5"
        Click="Event_Click"/>
        <Button 
         Grid.Column="2" 
         Grid.Row="1" 
         x:Name="btn5" 
         Content="5" 
         FontSize="20" 
         Background="#FF8A8A8A"
         Margin="5"
        Click="Event_Click"/>
        <Button 
         Grid.Column="0" 
         Grid.Row="2" 
         x:Name="btn6" 
         Content="6" 
         FontSize="20" 
         Background="#FF8A8A8A"
         Margin="5"
        Click="Event_Click"/>
        <Button 
         Grid.Column="1" 
         Grid.Row="2" 
         x:Name="btn7" 
         Content="7" 
         FontSize="20" 
         Background="#FF8A8A8A"
         Margin="5"
        Click="Event_Click" Foreground="Black" BorderBrush="#FF8A8383"/>
        <Button 
         Grid.Column="2" 
         Grid.Row="2" 
         x:Name="btn8" 
         Content="8" 
         FontSize="20" 
         Background="#FF8A8A8A"
         Margin="5"
        Click="Event_Click"/>
        <Button 
         Grid.Column="1" 
         Grid.Row="3" 
         x:Name="btn9" 
         Content="9" 
         FontSize="20" 
         Background="#FF8A8A8A"
         Margin="5"
        Click="Event_Click"/>

        <Button 
         Grid.Column="3" 
         Grid.Row="0" 
         x:Name="btnSoma" 
         Content="+" 
         FontSize="40" 
         Background="#FF8A8A8A"
         Margin="5"
        Click="Event_Click"/>
        <Button 
         Grid.Column="3" 
         Grid.Row="1" 
         x:Name="btnSub" 
         Content="-" 
         FontSize="40" 
         Background="#FF8A8A8A"
         Margin="5"
        Click="Event_Click"/>
        <Button 
         Grid.Column="3" 
         Grid.Row="2" 
         x:Name="btnMult" 
         Content="x" 
         FontSize="40" 
         Background="#FF8A8A8A"
         Margin="5"
        Click="Event_Click"/>
        <Button 
         Grid.Column="3" 
         Grid.Row="3" 
         x:Name="btnIgual" 
         Content="=" 
         FontSize="40" 
         Background="#FF8A8A8A"
         Margin="5"
        Click="Event_Click"/>
        <TextBox
            Grid.ColumnSpan="4" 
            HorizontalAlignment="Center" 
            Margin="5,-84,0,0" 
            TextWrapping="Wrap" 
            VerticalAlignment="Top" 
            Width="363" 
            Height="57"
            FontSize="30"
            x:Name="textarea" TextAlignment="Right"
            />
    </Grid>

</Window>
